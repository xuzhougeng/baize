#!/bin/sh

set -eu

msg_file="${1:-}"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
    echo "commit-msg hook requires a commit message file" >&2
    exit 1
fi

first_line="$(sed -n '1{s/\r$//;p;}' "$msg_file")"

case "$first_line" in
    Merge\ *|Revert\ *)
        exit 0
        ;;
esac

pattern='^(feat|docs|chore)(\([a-z0-9._/-]+\))?!?: .+$'
if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
    exit 0
fi

cat >&2 <<'EOF'
Invalid commit message.

Expected:
  feat(scope): short summary
  docs(scope): short summary
  chore(scope): short summary

Allowed types:
  feat
  docs
  chore

Examples:
  feat(weixin): add basic bridge loop
  docs(readme): document windows build flow
  chore(hooks): enforce commit message format
EOF

exit 1
